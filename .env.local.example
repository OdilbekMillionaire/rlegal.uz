# ─────────────────────────────────────────────────────────────
# R-LEGAL PRACTICE — Environment Variables
# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="R-Legal Practice"

# AI Provider API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...
MISTRAL_API_KEY=...
GROQ_API_KEY=gsk_...

# Default AI Model (for intake specialist)
NEXT_PUBLIC_DEFAULT_AI_MODEL=claude-sonnet-4-6

# Email (contact form)
RESEND_API_KEY=re_...
CONTACT_EMAIL=rlegalpractice@gmail.com

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-...
NEXT_PUBLIC_POSTHOG_KEY=phc_...
